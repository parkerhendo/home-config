#!/usr/bin/env bash

if [[ -n $1 ]]; then
  SSID=$1
else
  SSID=$(system_profiler SPAirPortDataType 2>/dev/null | awk '/Current Network Information:/{getline; gsub(/^ *| *:$/,""); print; exit}')
  if [[ -z $SSID ]]; then
    printf "Could not detect Wi-Fi network. Enter SSID: "
    read -r SSID
    [[ -n $SSID ]] || { echo "no SSID provided"; exit 1; }
  fi
fi

echo -e "\033[90m … getting password for \"${SSID}\" \033[39m"
PASS=$(security find-generic-password -D "AirPort network password" -a "${SSID}" -w /Library/Keychains/System.keychain 2>/dev/null)
(( $? == 128 )) && { echo "user cancelled"; exit 0; }
[[ -n $PASS ]] || { echo 1>&2 "password for \"${SSID}\" not found in Keychain"; exit 1; }
echo -e "\033[96m ✓ ${PASS} \033[39m"
