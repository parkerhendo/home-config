{
  "mcpServers": {
    "sentry": {
      "command": "npx",
      "args": ["-y", "mcp-remote@latest", "https://mcp.sentry.dev/mcp"],
      "directTools": true
    },
    "vercel": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.vercel.com"],
      "directTools": true
    },
    "braintrust": {
      "url": "https://api.braintrust.dev/mcp",
      "auth": "bearer",
      "bearerTokenEnv": "BRAINTRUST_API_KEY"
    },

    "datadog": {
      "url": "https://mcp.us5.datadoghq.com/api/unstable/mcp-server/mcp"
    }
  }
}
